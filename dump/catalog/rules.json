      "labelKey": "K_IGU_21",
      "labelNs": "NS_UGC_SETTINGS",
      "descriptionKey": "K_IGU_02",
      "descriptionNs": "NS_UGC_SETTINGS",
      "label": "Round Count\t",
      "description": "Set the total number of rounds.\r\nIf a team wins more than half of the total rounds, that team is declared the winner and the match ends.\r\nIf there are three or more teams and the number of wins is tied, all tied teams are declared winners."
    },
    {
      "path": "goalScore",
      "schemaPath": "GoalScore",
      "type": "Int",
      "unrealType": "IntProperty",
      "validator": "Class'/Script/TslGameMode.ModIntValidator'",
