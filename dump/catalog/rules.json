        "minValue": 1,
        "maxValue": 9999,
        "valueSet": []
      },
      "advanced": false,
      "hidden": false,
      "labelKey": "K_IGU_22",
      "labelNs": "NS_UGC_SETTINGS",
      "descriptionKey": "K_IGU_03",
      "descriptionNs": "NS_UGC_SETTINGS",
      "label": "Target Score",
      "description": "Set the target score required to win.\r\nThe round ends when a team or player reaches the target score.\r\nIf no one reaches the target score, the team or player with the higher score wins.\r\nIf scores are tied, all tied teams are awarded one win."
    },
